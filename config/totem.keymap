//
//                                                        ▀▀▀▀▀     ▀▀▀▀▀          ▀▀█▀▀
//                                                        ▄▀▀▀▄  ▄  ▄▀▀▀▄  ▄  ▄▀▀▀▄  █  ▄▀▀▀▄
//                                                        █   █  █  █   █  █  █   █  █  █   █
//                                                         ▀▀▀   █   ▀▀▀   █   ▀▀▀   ▀   ▀▀▀
//                                                               █      ▄▄▄█▄▄▄    █   █  
//                                                               ▀      █  █  █     █▄█
//                                                             ▀▀▀▀▀    █  █  █      ▀
//                                                                      ▀  ▀  ▀
//
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define BASE 0
#define NAV  1
#define SYM  2
#define ADJ  3
#define TVP1 4
#define TVP2 5

&sk { quick-release; };

/ {
    combos {
        compatible = "zmk,combos";

        delete {
            bindings = <&kp DELETE>;
            key-positions = <18 17>;
        };

        backspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <17 16>;
        };

        bt_clear_profile {
            bindings = <&bt BT_CLR>;
            key-positions = <20 11 12 13>;
        };

        bt_sel_0 {
            bindings = <&bt BT_SEL 0>;
            key-positions = <25 24 20>;
        };

        bt_sel_1 {
            bindings = <&bt BT_SEL 1>;
            key-positions = <14 13 20>;
        };

        bt_sel_2 {
            bindings = <&bt BT_SEL 2>;
            key-positions = <4 3 20>;
        };

        caps {
            bindings = <&caps_word>;
            key-positions = <13 16>;
        };

        heptabase_highlight {
            bindings = <&hb_hl>;
            key-positions = <12 13 11>;
            layers = <4>;
        };

        cmd {
            bindings = <&kp LEFT_COMMAND>;
            key-positions = <33 34>;
        };

        alt {
            bindings = <&kp LEFT_ALT>;
            key-positions = <35 36>;
        };

        stick_shift {
            bindings = <&sk LEFT_SHIFT>;
            key-positions = <13 12>;
            layers = <0 1 2 3>;
        };

        to_heptabase {
            bindings = <&tog 4>;
            key-positions = <0 1 2 3>;
        };

        undo {
            bindings = <&kp LG(Z)>;
            key-positions = <0 1>;
            require-prior-idle-ms = <100>;
        };

        redo {
            bindings = <&kp LS(LG(Z))>;
            key-positions = <2 3>;
            require-prior-idle-ms = <100>;
        };

        heptabase_del {
            bindings = <&kp DEL>;
            key-positions = <12 13>;
            layers = <4>;
        };

        switch_lang {
            bindings = <&kp LC(SPACE)>;
            key-positions = <34 35>;
        };
    };

    behaviors {
        hml: homewrow_mods_left {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_LEFT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <280>;
            hold-trigger-key-positions = <35 36 37 26 27 28 29 30 31 15 16 17 18 19 5 6 7 8 9>;
            flavor = "balanced";
            hold-trigger-on-release;
            quick-tap-ms = <175>;
        };

        hmr: homewrow_mods_right {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_RIGHT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <280>;
            hold-trigger-key-positions = <0 10 20 21 1 2 3 4 11 12 13 14 22 23 24 25 32 33 34>;
            require-prior-idle-ms = <175>;
            flavor = "balanced";
            hold-trigger-on-release;
        };
    };

    macros {
        hb_hl: hb_hl {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LCMD &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp H>,
                <&macro_release>,
                <&kp LCMD &kp LEFT_SHIFT>;

            label = "HB_HL";
        };

        hb_conv: hb_conv {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&macro_press>,
                <&kp LCMD &kp LEFT_ALT &macro_param_1to1>,
                <&macro_tap>,
                <&kp MACRO_PLACEHOLDER>,
                <&macro_release>,
                <&kp LCMD &kp LEFT_ALT>;

            label = "HB_CONV";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        base_layer {
            // ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓

            label = "BASE";

            // ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
            //             ┏━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┓   ┏━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┓
            //             ┃     Q     ┃     W     ┃     F     ┃     P     ┃     G     ┃   ┃     J     ┃     L     ┃     U     ┃     Y     ┃     ;     ┃
            //             ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫
            //             ┃     A     ┃     R     ┃     S     ┃     T     ┃     D     ┃   ┃     H     ┃     N     ┃     E     ┃     I     ┃     O     ┃
            // ┏━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┓
            // ┃     Q     ┃     Z     ┃     X     ┃     C     ┃     V     ┃     B     ┃   ┃     K     ┃     M     ┃     ,     ┃     .     ┃     /     ┃     \     ┃
            // ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛
            //                                     ┃    DEL    ┃    TAB    ┃    SPC    ┃   ┃   ENTER   ┃           ┃   BSPC    ┃
            //                                     ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛   ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛

            bindings = <
         &kp Q              &kp W         &kp E            &kp R            &kp T      &kp Y      &kp U            &kp I             &kp O         &kp P
         &hml LEFT_SHIFT A  &hml LCTRL S  &hml LEFT_ALT D  &hml LEFT_GUI F  &kp G      &kp H      &hmr LEFT_GUI J  &hmr RIGHT_ALT K  &hmr RCTRL L  &hmr RIGHT_SHIFT SEMICOLON
&kp TAB  &kp Z              &kp X         &kp C            &kp V            &kp B      &kp N      &kp M            &kp COMMA         &kp DOT       &kp FSLH                    &kp SQT
                                          &tog 1           &kp ESCAPE       &kp SPACE  &kp ENTER  &kp RIGHT_GUI    &tog 2
            >;
        };

        numbers_layer {
            bindings = <
        &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &kp NUMBER_7  &kp N8  &kp NUMBER_9  &kp N0
        &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans  &trans        &trans
&trans  &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans  &trans        &trans  &trans
                                    &trans        &trans        &trans        &trans        &trans        &trans
            >;

            label = "NUMBER";
        };

        nav_layer {
            bindings = <
        &kp C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC  &kp C_VOL_DN      &kp C_VOLUME_UP  &trans  &kp LA(LEFT)  &kp LA(DOWN)  &kp LA(UP)  &kp LA(RIGHT)  &trans
        &trans                &trans                &trans            &trans           &trans  &kp LEFT      &kp DOWN      &kp UP      &kp RIGHT      &trans
&trans  &trans                &kp C_PREV            &kp C_PLAY_PAUSE  &kp C_NEXT       &trans  &kp HOME      &kp PG_DN     &kp PG_UP   &kp END        &trans  &trans
                                                    &trans            &trans           &trans  &trans        &trans        &trans
            >;

            label = "NAV";
        };

        special_char_layer {
            bindings = <
           &kp EXCLAMATION  &kp AT_SIGN  &kp POUND  &kp DOLLAR  &kp PERCENT  &kp CARET       &kp AMPERSAND  &kp ASTERISK      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS
           &trans           &trans       &trans     &trans      &trans       &kp MINUS       &kp EQUAL      &kp LEFT_BRACKET  &kp RIGHT_BRACKET     &kp BACKSLASH
&kp TILDE  &kp GRAVE        &trans       &trans     &trans      &trans       &kp UNDERSCORE  &kp PLUS       &kp LEFT_BRACE    &kp RIGHT_BRACE       &kp PIPE               &kp SQT
                                         &trans     &trans      &trans       &trans          &trans         &trans
            >;

            label = "SPECIAL";
        };

        heptabase {
            bindings = <
             &hb_conv NUMBER_1                 &hb_conv NUMBER_2             &hb_conv NUMBER_3               &trans     &trans     &trans  &trans  &trans  &trans  &trans
             &hml LEFT_SHIFT LG(LA(NUMBER_4))  &hml LEFT_CONTROL LA(LG(N5))  &hml LEFT_ALT LG(LA(NUMBER_6))  &trans     &kp LG(G)  &trans  &trans  &trans  &trans  &trans
&hb_conv N0  &hb_conv N7                       &hb_conv N8                   &hb_conv N9                     &kp C      &kp V      &trans  &trans  &trans  &trans  &trans  &trans
                                                                             &kp ESCAPE                      &kp SPACE  &kp ENTER  &trans  &trans  &trans
            >;

            label = "HEPTABASE";
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        special {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
